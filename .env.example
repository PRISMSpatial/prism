# Copy this to .env and fill in real values for production

# Backend API URL (FastAPI)
# In production: set this at build time, OR configure your web server
# to reverse-proxy /api/* to the FastAPI backend (the client falls back to /api)
VITE_API_BASE_URL=http://localhost:8100/api

# Set to "true" to use mock data instead of hitting the API
# When unset, defaults to mock in DEV mode and live in production builds
VITE_USE_MOCK=true
